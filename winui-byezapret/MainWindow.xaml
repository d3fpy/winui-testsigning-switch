<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="winui_byezapret.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Тестовый режим Windows">

    <Grid>
        <Image x:Name="BackgroundImage"
               Source="Assets/background.png"
               Stretch="UniformToFill"
               Opacity="0.15"/>

        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.04">
                    <GradientStop Color="#0078D4" Offset="0"/>
                    <GradientStop Color="#8A2BE2" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Padding="32,48,32,0">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE770;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Загрузка Windows" Style="{StaticResource TitleLargeTextBlockStyle}"/>
                    </StackPanel>
                    <TextBlock Text="Управление параметрами BCD и тестовым режимом"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="40,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Основной контент -->
            <ScrollViewer Grid.Row="1" Padding="32,24,32,0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12" MaxWidth="640">

                    <!-- Карточка тестового режима -->
                    <Border x:Name="TestModeCard"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CardTranslate" Y="30"/>
                        </Border.RenderTransform>
                        <Border.Resources>
                            <Storyboard x:Name="CardEnterAnimation">
                                <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 From="30" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="TestModeCard"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.4"/>
                            </Storyboard>
                        </Border.Resources>

                        <Grid VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="48" Height="48"
                                    CornerRadius="10"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0,0,16,0">
                                <FontIcon Glyph="&#xE8B8;" FontSize="22" Foreground="White"/>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Top">
                                <TextBlock Text="Тестовый режим" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Name="TestModeDescription"
                                           Text="Позволяет загружать неподписанные драйверы"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <Border x:Name="StatusBadge"
                                        Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        HorizontalAlignment="Left"
                                        Margin="0,4,0,0">
                                    <TextBlock x:Name="StatusText"
                                               Text="ВЫКЛЮЧЕН"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <ToggleSwitch x:Name="TestModeToggle"
                                          Grid.Column="2"
                                          VerticalAlignment="Top"
                                          Margin="12,0,0,0"
                                          OnContent=""
                                          OffContent=""
                                          Toggled="TestModeToggle_Toggled"/>
                        </Grid>
                    </Border>

                    <!-- Инфо-блок -->
                    <Border x:Name="InfoCard"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="InfoTranslate" Y="30"/>
                        </Border.RenderTransform>
                        <Border.Resources>
                            <Storyboard x:Name="InfoEnterAnimation">
                                <DoubleAnimation Storyboard.TargetName="InfoTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 From="30" To="0" Duration="0:0:0.5"
                                                 BeginTime="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="InfoCard"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.5"
                                                 BeginTime="0:0:0.1"/>
                            </Storyboard>
                        </Border.Resources>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE946;" FontSize="16"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                      VerticalAlignment="Top"
                                      Margin="0,2,12,0"/>

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="Что такое тестовый режим?"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Тестовый режим (testsigning) отключает проверку цифровой подписи драйверов. Это нужно для разработки и тестирования собственных драйверов. После включения потребуется перезагрузка."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- GitHub -->
                    <TextBlock x:Name="GithubText"
                               Text="github.com/d3fpy"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,24">
                        <TextBlock.Foreground>
                            <LinearGradientBrush x:Name="GithubGradient" StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop x:Name="GradStop1" Color="#0078D4" Offset="0"/>
                                <GradientStop x:Name="GradStop2" Color="#8A2BE2" Offset="0.5"/>
                                <GradientStop x:Name="GradStop3" Color="#00B4FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>

            <!-- Нижняя панель -->
            <Border Grid.Row="2"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Height="64">
                <Grid>
                    <Canvas x:Name="ParticleCanvas"/>
                    <Grid Padding="32,0">
                        <TextBlock x:Name="FooterText"
                                   Text="Готово"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="bcdedit /set testsigning"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontFamily="Cascadia Code, Consolas"/>
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>